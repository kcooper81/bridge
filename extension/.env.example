# TeamPrompt Extension Environment Variables
# Copy this file to .env and fill in your actual values

# Your TeamPrompt website URL
WXT_SITE_URL=https://teamprompt.app

# Supabase Configuration (get from your Supabase project settings)
WXT_SUPABASE_URL=https://your-project-id.supabase.co
WXT_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# IMPORTANT SECURITY NOTES:
# 1. Never commit real API keys to version control
# 2. Use environment-specific keys for development/staging/production
# 3. Rotate keys regularly if compromised
# 4. Use the minimum required permissions for each key
