{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.teamprompt.app" }],
      "destination": "https://teamprompt.app/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/extension-check",
      "schedule": "0 8 * * *"
    }
  ]
}
